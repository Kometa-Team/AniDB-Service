# SIMKL OAuth Configuration
# Copy this file to .env and fill in your values

# === Required ===
# SIMKL app credentials — obtain from https://simkl.com/settings/developer/
CLIENT_ID=your_simkl_client_id
CLIENT_SECRET=your_simkl_client_secret

# Callback URL registered in your SIMKL app settings
# For path-based deployment: https://yourdomain.com/simkl-oauth/callback
# For local development:     http://localhost:8080/callback
REDIRECT_URI=https://yourdomain.com/simkl-oauth/callback

# === Optional ===
# Set to /simkl-oauth for path-based routing behind a reverse proxy (e.g. Caddy)
# Leave empty for subdomain deployment (simkl-oauth.yourdomain.com)
ROOT_PATH=/simkl-oauth

# Flask server settings (local development only — gunicorn ignores these)
PORT=8080
HOST=127.0.0.1
DEBUG=False
