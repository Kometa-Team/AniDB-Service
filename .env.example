# AniDB Service Configuration
# Copy this file to .env and update with your actual values

# === AniDB API Configuration ===
ANIDB_CLIENT=kometaofficial
ANIDB_VERSION=1
ANIDB_PROTO_VER=1

# AniDB Authentication (required for accessing mature/18+ content)
# Register at: https://anidb.net/
ANIDB_USERNAME=your_anidb_username
ANIDB_PASSWORD=your_anidb_password

# === Rate Limiting ===
DAILY_LIMIT=200
THROTTLE_SECONDS=4
UPDATE_THRESHOLD_DAYS=7

# === File Paths (Docker defaults) ===
XML_DIR=/app/data
DB_PATH=/app/database.db
SEED_DATA_DIR=/app/seed_data

# === Path-Based Routing (Optional) ===
# Leave empty for subdomain deployment (anidb-service.yourdomain.com)
# Set to /anidb-service for path-based deployment (yourdomain.com/anidb-service)
# IMPORTANT: This must match the path in your Caddyfile
ROOT_PATH=/anidb-service

# === Backup Configuration ===
# Backups are created locally in ./backups/
# Optional: Use S3-compatible storage for off-site backups

# === AWS S3 / DigitalOcean Spaces Configuration ===
# For AWS S3: Use your AWS credentials and leave S3_ENDPOINT empty
# For DigitalOcean Spaces: Use Spaces keys and set the endpoint
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=nyc3
S3_BUCKET_NAME=anidb-backups
# For DigitalOcean Spaces, set the endpoint (leave empty for AWS S3)
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# === IMDb Service Parental Proxy Configuration ===
# Generic parental proxy pool used by the HTTP/browser retry flow
PARENTAL_PROXY_ENABLED=false
PARENTAL_PROXY_URLS=
PARENTAL_PROXY_RETRY_COUNT=1
PARENTAL_PROXY_BAN_TTL_MINUTES=30

# Optional: Use a sticky Decodo residential proxy specifically for the browser fallback
PARENTAL_DECODO_BROWSER_ENABLED=false
PARENTAL_DECODO_BROWSER_HOST=gate.decodo.com
PARENTAL_DECODO_BROWSER_PORT=7000
PARENTAL_DECODO_BROWSER_USERNAME=
PARENTAL_DECODO_BROWSER_PASSWORD=
PARENTAL_DECODO_BROWSER_COUNTRY=us
PARENTAL_DECODO_BROWSER_SESSION_DURATION_MINUTES=60
